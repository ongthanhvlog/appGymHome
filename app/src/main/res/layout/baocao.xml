<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".fragment.BaoCao_Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleBaoCao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Báo cáo"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Top stats card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số bài tập đã\nhoàn thành"
                        android:gravity="center"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTongBaiTapHoanThanh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#EEEEEE"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng calo"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTongCalo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#EEEEEE"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian Tập luyện"
                        android:gravity="center"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTongThoiGianTapLuyen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BMI Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BMI"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"/>
                    <Button
                        android:id="@+id/btnChinhSuaBMI"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Chỉnh sửa"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:backgroundTint="#2196F3"
                        android:textColor="@color/white"
                        android:layout_alignParentRight="true"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:id="@+id/tvChiSoBMI"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="32sp"
                        android:textStyle="bold"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <ImageView
                        android:id="@+id/ivBMIPhanLoaiColor"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/circle_red"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tvBMIPhanLoai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bình thường"
                        android:textColor="@color/black"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- BMI Scale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_centerInParent="true"
                            android:orientation="horizontal">
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="18.5" android:background="#3F51B5"/>
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="6.5" android:background="#4CAF50"/>
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:background="#FFEB3B"/>
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:background="#FF9800"/>
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:background="#F44336"/>
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:background="#B71C1C"/>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivBMIPointer"
                            android:layout_width="12dp"
                            android:layout_height="8dp"
                            android:src="@drawable/ic_pointer_arrow"
                            android:layout_alignParentTop="true"
                            android:layout_marginTop="1dp"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="18.5" android:text="15" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="6.5" android:text="18.5" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="5" android:text="25" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="5" android:text="30" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="5" android:text="35" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="10" android:text="40" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Height Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiều cao"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/tvChieuCao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 cm"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Weight Chart Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cân nặng"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hiện tại"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvCanNang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 kg"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentRight="true">
                        <TextView
                            android:id="@+id/tvMaxCanNang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nặng nhất  0.0 kg"
                            android:textSize="14sp"
                            android:gravity="right"/>
                        <TextView
                            android:id="@+id/tvMinCanNang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhẹ nhất   0.0 kg"
                            android:textSize="14sp"
                            android:gravity="right"/>
                    </LinearLayout>
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/bieuDoCanNang"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
